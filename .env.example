# RFP Platform — Environment variables
# Copy to .env and fill in secrets

# --- Secrets (REQUIRED — set real values in production) ---
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me_to_a_random_64_char_string

# --- Secrets (REQUIRED for LLM features) ---
LITELLM_API_KEY=sk-...

# MinIO
MINIO_SECRET_KEY=change_me

# --- Configurable ---
LITELLM_PROVIDER=openai
LITELLM_MODEL=gpt-4o
RFP_MAX_UPLOAD_MB=50
CELERY_CONCURRENCY=4
RATE_LIMIT_PER_MIN=100
HTTP_PORT=80
HTTPS_PORT=443
LETSENCRYPT_EMAIL=admin@example.com

# --- Defaults (rarely change) ---
POSTGRES_DB=rfp
POSTGRES_USER=rfp
MINIO_ACCESS_KEY=rfp_access
